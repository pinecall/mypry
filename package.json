{
  "name": "mypry",
  "version": "0.1.0-beta.5",
  "description": "Fullstack debugger for AI agents — debug Node.js + browser via MCP",
  "author": "Pinecall",
  "license": "MIT",
  "homepage": "https://github.com/pinecall/mypry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinecall/mypry.git"
  },
  "bugs": {
    "url": "https://github.com/pinecall/mypry/issues"
  },
  "keywords": [
    "debugger",
    "mcp",
    "node",
    "browser",
    "cdp",
    "ai",
    "agent",
    "fullstack",
    "playwright"
  ],
  "type": "module",
  "main": "./dist/fullstack-toolkit.js",
  "types": "./dist/fullstack-toolkit.d.ts",
  "bin": {
    "mypry-bridge": "dist/mcp-bridge.js"
  },
  "exports": {
    ".": {
      "import": "./dist/fullstack-toolkit.js",
      "types": "./dist/fullstack-toolkit.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./toolkit": {
      "import": "./dist/fullstack-toolkit.js",
      "types": "./dist/fullstack-toolkit.d.ts"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": ">=1.52",
    "source-map": "^0.7.6"
  }
}
