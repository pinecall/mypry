{
  "name": "mypry",
  "version": "0.1.0",
  "description": "Node + browser debugger with inline pry() trigger, REPL, MCP, and HTTP — pairs with your AI agent",
  "type": "module",
  "main": "./lib/pry.cjs",
  "types": "./dist/pry.d.ts",
  "bin": {
    "mypry": "./bin/mypry"
  },
  "exports": {
    ".": {
      "require": "./lib/pry.cjs",
      "import": "./dist/pry.js",
      "types": "./dist/pry.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    },
    "./mcp": {
      "import": "./dist/transports/mcp.js",
      "types": "./dist/transports/mcp.d.ts"
    },
    "./http": {
      "import": "./dist/transports/http.js",
      "types": "./dist/transports/http.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "npm run test:contract && npm run test:suite",
    "test:contract": "node test-aurora-contract.cjs",
    "test:suite": "tsc -p tsconfig.test.json && node --test dist-test/test/ndjson-contract.test.js",
    "example": "node examples/test.js"
  },
  "keywords": [
    "debugger",
    "pry",
    "node",
    "browser",
    "cdp",
    "mcp",
    "http",
    "ai",
    "agent",
    "repl"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "source-map": "^0.7.6"
  }
}
